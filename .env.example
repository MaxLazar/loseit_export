# Lose It! account credentials
LOSEIT_EMAIL=your@email.com
LOSEIT_PASSWORD=your_password

# Number of days to include in the export (default: 1 = today only)
DAYS_RANGE=1

# GitHub repo for --deploy (format: owner/repo)
GITHUB_REPO=your-github-username/your-repo-name

# Intervals.icu integration (optional — omit to skip posting)
INTERVALS_ATHLETE_ID=your_athlete_id
INTERVALS_API_KEY=your_api_key
